session_start();

// 2. SECURITY CHECK
// If the session 'user_name' is not set, it means the user didn't log in.
// We kick them back to the login page.
if (!isset($_SESSION['user_name'])) {
    header("Location: login.php");
    exit();
}

// 3. GET THE REAL NAME
// Now we pull the actual name from the session (e.g., "Maria Santos")
$customerName = $_SESSION['user_name'];
?>

