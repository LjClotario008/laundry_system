    <script>
        // PASS PHP DATA TO JAVASCRIPT
        // This is where the "Baton Pass" happens.
        const customerName = "<?php echo htmlspecialchars($customerName); ?>"; 

        const pages = {
            overview: `
                <div class="overview_container">
                    <div class="welcome_msg">
                        <h1>Welcome Back, ${customerName}!</h1>
                        <p>What can we wash for you today?</p>
                    </div>
                    <div class="services_grid">
                        <div class="service_card">
                            <div class="service_icon"><i class="fas fa-tshirt"></i></div>
                            <h3>Wash & Fold</h3>
                            <p>Standard laundry service for your everyday clothes.</p>
                            <button class="get_started_btn" onclick="loadPage('neworder')">Book Now</button>
                        </div>
                        <div class="service_card">
                            <div class="service_icon"><i class="fas fa-soap"></i></div>
                            <h3>Dry Cleaning</h3>
                            <p>Professional care for your delicate and formal wear.</p>
                            <button class="get_started_btn" onclick="loadPage('neworder')">Book Now</button>
                        </div>
                        <div class="service_card">
                            <div class="service_icon"><i class="fas fa-bed"></i></div>
                            <h3>Household</h3>
                            <p>Expert cleaning for comforters, curtains, and sheets.</p>
                            <button class="get_started_btn" onclick="loadPage('neworder')">Book Now</button>
                        </div>
                    </div>
                </div>
            `,
            neworder: `<div class="page_header"><h1>New Order</h1><p>Start a new laundry request.</p></div>`,
            myhistory: `<div class="page_header"><h1>My History</h1><p>View your past orders.</p></div>`,
            settings: `<div class="page_header"><h1>Settings</h1><p>Manage your account info.</p></div>`
        };

        const contentArea = document.getElementById('content-area');
        const navLinks = document.querySelectorAll('.sidebar nav a');

        function loadPage(pageKey) {
            const key = pageKey.toLowerCase().replace(/\s/g, '');
            if (pages[key]) {
                contentArea.innerHTML = pages[key];
                navLinks.forEach(link => {
                    link.classList.remove('active');
                    const linkText = link.innerText.trim().toLowerCase().replace(/\s/g, '');
                    if (linkText === key) link.classList.add('active');
                });
            }
        }

        navLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                if (this.classList.contains('logout')) return;
                e.preventDefault();
                loadPage(this.innerText.trim());
            });
        });

        loadPage('overview');
    </script>
